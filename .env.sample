# Required
LMGATE_AUTH_ADMIN_EMAIL = <email of local admin user>
LMGATE_AUTH_JWT_SECRET = <super secret for your JWT tokens>
LMGATE_ENCRYPTION_KEY = <super secret to encrypt sensitive data>
LMGATE_UPSTREAM_URL = http://localhost:11434

# Change to false when in production
LMGATE_TLS_DISABLED = true

# Default: 80 (HTTP) or 443 (HTTPS)
# --dev Default: 8080 (HTTP) or 8443 (HTTPS)
# LMGATE_ALLOWED_HOSTS = example.com
# LMGATE_LISTEN = 8080

# Admin Network Restriction (optional)
# LMGATE_ADMIN_ALLOWED_NETWORKS = 127.0.0.1,::1

# Logging (optional)
# Audit log flush interval in seconds (default: 5)
# LMGATE_AUDIT_FLUSH_INTERVAL = 5

# One time install count telemetry ping (optional, enabled by default)
# LMGATE_TELEMETRY_DISABLED = true

# WebAuthn / Passkey Support (optional)
# Set RP_ID to your domain to enable passkey registration and login
# LMGATE_WEBAUTHN_RP_ID = example.com
# LMGATE_WEBAUTHN_RP_DISPLAY_NAME = LM Gate
# LMGATE_WEBAUTHN_RP_ORIGINS = https://example.com
